<Window x:Class="QuanLyNhaHang.View.User"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:QuanLyNhaHang.ViewModel"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp" 
        xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity"
        mc:Ignorable="d"
        x:Name="Window"
        TextElement.FontFamily="Comfortaa Light"
        DataContext="{StaticResource MainVM}"
        Title="Thông tin cá nhân tài khoản" Height="700" Width="850" WindowStyle="None" WindowStartupLocation="CenterScreen"
        AllowsTransparency="True" Background="Transparent">

    <Grid>
        <Border Background="White" CornerRadius="12" Margin="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="2" Color="#000000" Opacity="0.15"/>
            </Border.Effect>

            <Grid>
                <Grid.Resources>
                    <Style x:Key="FormFieldBorder" TargetType="Border">
                        <Setter Property="Background" Value="#F1F5F9" />
                        <Setter Property="CornerRadius" Value="8"/>
                        <Setter Property="Height" Value="45"/>
                        <Setter Property="Padding" Value="10 0"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#CBD5E1"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <Style x:Key="FormFieldTextBox" TargetType="TextBox">
                        <Setter Property="Foreground" Value="#1E293B"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="FontSize" Value="16"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="FontFamily" Value="Comfortaa"/>
                    </Style>

                    <Style x:Key="FormLabel" TargetType="TextBlock">
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Foreground" Value="#64748B"/>
                        <Setter Property="Margin" Value="2 0 0 6"/>
                    </Style>

                    <Style x:Key="CloseButtonStyle" TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#94A3B8"/>
                        <Setter Property="Width" Value="35"/>
                        <Setter Property="Height" Value="35"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="17.5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FEE2E2"/>
                                <Setter Property="Foreground" Value="#EF4444"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Resources>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="25 20 25 15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0 0 25 0">
                        <Border Width="110" Height="110" CornerRadius="55" BorderThickness="3" BorderBrush="#1C3879" Background="#F1F5F9">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.2"/>
                            </Border.Effect>
                            <Ellipse Width="104" Height="104">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{Binding CaiDatViewModel.NhanVien.AnhDaiDien}" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                        </Border>

                        <Button Width="36" Height="36" Background="#1C3879" BorderThickness="2" BorderBrush="White"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0 0 0 0" Cursor="Hand"
                                Command="{Binding CaiDatViewModel.ChangeProfileImage}" ToolTip="Đổi ảnh đại diện"
                                materialDesign:ButtonAssist.CornerRadius="18" Padding="0">
                            <fa:IconImage Icon="Camera" Width="16" Height="16" Foreground="White" />
                        </Button>
                    </Grid>

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="{Binding CaiDatViewModel.NhanVien.HoTen}" FontSize="28" FontWeight="Bold" Foreground="#1E293B" Margin="0 0 0 5"/>
                        <TextBlock Grid.Row="1" Text="{Binding CaiDatViewModel.Role}" FontSize="16" FontStyle="Italic" Foreground="#64748B"/>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0 15 0 0">
                            <Button Content="Hủy" Width="100" Height="40" Background="Transparent" Foreground="#64748B" BorderBrush="#CBD5E1" 
                                    Command="{Binding CaiDatViewModel.CancelCommand}" materialDesign:ButtonAssist.CornerRadius="6" Cursor="Hand"/>
                            <Button Content="Lưu Thay Đổi" Width="130" Height="40" Background="#1C3879" Foreground="White" BorderThickness="0"
                                    Margin="15 0 0 0" Command="{Binding CaiDatViewModel.UpdateInfoCommand}" materialDesign:ButtonAssist.CornerRadius="6" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>

                    <Button Grid.Column="2" Style="{StaticResource CloseButtonStyle}" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="-10 -10 0 0"
                            Command="{Binding CaiDatViewModel.CloseWindowCommand}" CommandParameter="{Binding ElementName=Window}">
                        <fa:IconImage Icon="Times" Width="16" Height="16" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                    </Button>
                </Grid>

                <Separator Grid.Row="1" Background="#E2E8F0" Margin="20 0"/>

                <TabControl Grid.Row="2" Style="{StaticResource MaterialDesignTabControl}" materialDesign:ShadowAssist.ShadowDepth="Depth0" Margin="20 10 20 20" Background="Transparent">

                    <TabItem Header="Thông tin cá nhân" Cursor="Hand">
                        <Grid Margin="10 20 10 0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Margin="0 0 0 20">
                                    <TextBlock Text="Họ tên" Style="{StaticResource FormLabel}"/>
                                    <Border Style="{StaticResource FormFieldBorder}">
                                        <TextBox Style="{StaticResource FormFieldTextBox}" Text="{Binding CaiDatViewModel.NhanVien.HoTen}"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Margin="0 0 0 20">
                                    <TextBlock Text="Ngày sinh" Style="{StaticResource FormLabel}"/>
                                    <Border Style="{StaticResource FormFieldBorder}">
                                        <DatePicker SelectedDate="{Binding CaiDatViewModel.NhanVien.NgaySinh}" FontSize="16" Foreground="#1E293B" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" materialDesign:TextFieldAssist.DecorationVisibility="Hidden"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Margin="0 0 0 20">
                                    <TextBlock Text="Ngày vào làm" Style="{StaticResource FormLabel}"/>
                                    <Border Style="{StaticResource FormFieldBorder}" Background="#F8FAFC">
                                        <TextBox Style="{StaticResource FormFieldTextBox}" Text="{Binding CaiDatViewModel.NhanVien.NgayVaoLam, StringFormat='{}{0:dd/MM/yyyy}'}" IsReadOnly="True" Foreground="#94A3B8"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Margin="0 0 0 20">
                                    <TextBlock Text="Địa chỉ" Style="{StaticResource FormLabel}"/>
                                    <Border Style="{StaticResource FormFieldBorder}">
                                        <TextBox Style="{StaticResource FormFieldTextBox}" Text="{Binding CaiDatViewModel.NhanVien.DiaChi}"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <StackPanel Margin="0 0 0 20">
                                    <TextBlock Text="Mã nhân viên" Style="{StaticResource FormLabel}"/>
                                    <Border Style="{StaticResource FormFieldBorder}" Background="#F8FAFC">
                                        <TextBox Style="{StaticResource FormFieldTextBox}" Text="{Binding CaiDatViewModel.NhanVien.MaNV}" IsReadOnly="True" Foreground="#94A3B8"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Margin="0 0 0 20">
                                    <TextBlock Text="Chức vụ" Style="{StaticResource FormLabel}"/>
                                    <Border Style="{StaticResource FormFieldBorder}" Background="#F8FAFC">
                                        <TextBox Style="{StaticResource FormFieldTextBox}" Text="{Binding CaiDatViewModel.NhanVien.ChucVu}" IsReadOnly="True" Foreground="#94A3B8"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Margin="0 0 0 20">
                                    <TextBlock Text="Số điện thoại" Style="{StaticResource FormLabel}"/>
                                    <Border Style="{StaticResource FormFieldBorder}">
                                        <TextBox Style="{StaticResource FormFieldTextBox}" Text="{Binding CaiDatViewModel.NhanVien.SDT}"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Margin="0 0 0 20">
                                    <TextBlock Text="Loại nhân viên" Style="{StaticResource FormLabel}"/>
                                    <Border Style="{StaticResource FormFieldBorder}" Background="#F8FAFC">
                                        <TextBox Style="{StaticResource FormFieldTextBox}" Text="{Binding CaiDatViewModel.LoaiNhanVien_Str}" IsReadOnly="True" Foreground="#94A3B8"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Đổi mật khẩu" Cursor="Hand" Foreground="#1C3879">
                        <Grid x:Name="Container">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Width="400" Margin="0 20 0 0">

                                <Grid Margin="0 0 0 20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <PasswordBox x:Name="currentPassword" FontSize="18" materialDesign:HintAssist.Hint="Mật khẩu hiện tại" Foreground="#1E293B" Style="{StaticResource MaterialDesignFloatingHintPasswordBox}">
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="PasswordChanged" >
                                                    <i:InvokeCommandAction Command="{Binding CaiDatViewModel.CurrentPasswordChangedCommand}" CommandParameter="{Binding ElementName=currentPassword, Mode=OneWay}"/>
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                        </PasswordBox>
                                        <TextBox x:Name="currentpasswordTxtBox" FontSize="18" materialDesign:HintAssist.Hint="Mật khẩu hiện tại" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Visibility="Collapsed" />
                                    </Grid>
                                    <CheckBox Grid.Column="1" Content="Hiện mật khẩu" Name="showCurrentPassword" Margin="15 15 0 0"
                                              Unchecked="ShowCurrentPassword_Unchecked" Checked="ShowCurrentPassword_Checked" VerticalAlignment="Center" Foreground="#64748B"/>
                                </Grid>

                                <Grid Margin="0 0 0 20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <PasswordBox Name="newPassword" FontSize="18" materialDesign:HintAssist.Hint="Mật khẩu mới" Foreground="#1E293B" Style="{StaticResource MaterialDesignFloatingHintPasswordBox}">
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="PasswordChanged" >
                                                    <i:InvokeCommandAction Command="{Binding CaiDatViewModel.NewPasswordChangedCommand}" CommandParameter="{Binding ElementName=newPassword, Mode=OneWay}"/>
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                        </PasswordBox>
                                        <TextBox x:Name="newpasswordTxtBox" FontSize="18" materialDesign:HintAssist.Hint="Mật khẩu mới" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Visibility="Collapsed" />
                                    </Grid>
                                    <CheckBox Grid.Column="1" Content="Hiện mật khẩu" Name="showNewPassword" Margin="15 15 0 0"
                                              Unchecked="ShowNewPassword_Unchecked" Checked="ShowNewPassword_Checked" VerticalAlignment="Center" Foreground="#64748B"/>
                                </Grid>

                                <Grid Margin="0 0 0 40">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <PasswordBox Name="confirmPassword" FontSize="18" materialDesign:HintAssist.Hint="Xác nhận mật khẩu" Foreground="#1E293B" Style="{StaticResource MaterialDesignFloatingHintPasswordBox}">
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="PasswordChanged" >
                                                    <i:InvokeCommandAction Command="{Binding CaiDatViewModel.ConfirmPasswordChangedCommand}" CommandParameter="{Binding ElementName=confirmPassword, Mode=OneWay}"/>
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                        </PasswordBox>
                                        <TextBox Name="confirmpasswordTxtBox" FontSize="18" materialDesign:HintAssist.Hint="Xác nhận mật khẩu" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Visibility="Collapsed" />
                                    </Grid>
                                    <CheckBox Grid.Column="1" Content="Hiện mật khẩu" Name="showConfirmPassword" Margin="15 15 0 0"
                                              Unchecked="ShowConfirmPassword_Unchecked" Checked="ShowConfirmPassword_Checked" VerticalAlignment="Center" Foreground="#64748B"/>
                                </Grid>

                                <Button Click="doimatkhau_click" Command="{Binding CaiDatViewModel.ChangePassword}" Content="CẬP NHẬT MẬT KHẨU"
                                        Height="45" FontSize="16" FontWeight="Bold" Background="#1C3879" materialDesign:ButtonAssist.CornerRadius="8" Cursor="Hand"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>
    </Grid>
</Window>