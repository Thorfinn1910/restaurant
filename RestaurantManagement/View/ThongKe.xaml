<UserControl
        x:Class="QuanLyNhaHang.View.ThongKe"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        xmlns:local="clr-namespace:QuanLyNhaHang.View"
        xmlns:ViewModel="clr-namespace:QuanLyNhaHang.ViewModel" 
        TextElement.FontFamily="Comfortaa"
        TextElement.FontSize="16"
        mc:Ignorable="d" 
        d:DesignHeight="700" d:DesignWidth="1100"
        Background="#F4F6F9">
    <UserControl.DataContext>
        <ViewModel:ThongKeViewModel x:Name="vm"/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="25,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="60" Height="60" CornerRadius="30" Background="#E0F2FE">
                        <fa:IconImage Icon="ChartLine" Width="30" Height="30" Foreground="#0284C7"/>
                    </Border>
                    <StackPanel Margin="20,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="TỔNG THU DOANH NGHIỆP" FontSize="14" FontWeight="SemiBold" Foreground="#64748B"/>
                        <TextBlock Text="{Binding SumofProfit, UpdateSourceTrigger=PropertyChanged}" 
                                   FontSize="28" FontWeight="Bold" Foreground="#0284C7" Margin="0,5,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="25,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="60" Height="60" CornerRadius="30" Background="#FEE2E2">
                        <fa:IconImage Icon="MoneyBillTransfer" Width="30" Height="30" Foreground="#DC2626"/>
                    </Border>
                    <StackPanel Margin="20,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="TỔNG CHI PHÍ HOẠT ĐỘNG" FontSize="14" FontWeight="SemiBold" Foreground="#64748B"/>
                        <TextBlock Text="{Binding SumofPaid, UpdateSourceTrigger=PropertyChanged}" 
                                   FontSize="28" FontWeight="Bold" Foreground="#DC2626" Margin="0,5,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20,15" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05" Color="#000000"/>
            </Border.Effect>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <ComboBox Visibility="Collapsed" 
                          ItemsSource="{Binding Months}" 
                          SelectedItem="{Binding SelectedMonth, Mode=TwoWay}"/>

                <fa:IconImage Icon="Filter" Width="20" Height="20" Foreground="#94A3B8" Margin="0,0,10,0"/>
                <TextBlock Text="Xem thống kê theo năm:" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,15,0"/>

                <ComboBox Width="150" Height="40" FontSize="16"
                          VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                          MaxDropDownHeight="300" 
                          ItemsSource="{Binding Years}"
                          SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                </ComboBox>

                <Button Margin="20,0,0,0" Width="140" Height="40" Command="{Binding MonthYearCheckingCommand}" Cursor="Hand" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#1C3879" CornerRadius="8">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <fa:IconImage Icon="MagnifyingGlassChart" Width="16" Height="16" Foreground="White" Margin="0,0,8,0"/>
                                    <TextBlock Foreground="White" Text="LỌC DỮ LIỆU" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
            </Border.Effect>

            <lvc:CartesianChart Series="{Binding SeriesCollection}"
                                Visibility="{Binding Visibility}"
                                LegendLocation="Bottom"
                                Margin="10">
                <lvc:CartesianChart.AxisX>
                    <lvc:Axis Labels="{Binding Labels}"
                              FontFamily="Comfortaa"
                              Foreground="#64748B"
                              FontSize="13">
                        <lvc:Axis.Separator>
                            <lvc:Separator Step="1" StrokeThickness="0"/>
                        </lvc:Axis.Separator>
                    </lvc:Axis>
                </lvc:CartesianChart.AxisX>

                <lvc:CartesianChart.AxisY>
                    <lvc:Axis Title="Đơn vị: Triệu đồng" 
                              Foreground="#64748B"
                              FontFamily="Comfortaa"
                              FontSize="14"
                              LabelFormatter="{Binding Formatter}">
                        <lvc:Axis.Separator>
                            <lvc:Separator StrokeDashArray="4" Stroke="#E2E8F0"/>
                        </lvc:Axis.Separator>
                    </lvc:Axis>
                </lvc:CartesianChart.AxisY>
            </lvc:CartesianChart>
        </Border>

    </Grid>
</UserControl>