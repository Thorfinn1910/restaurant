<UserControl x:Class="QuanLyNhaHang.View.MenuAdmin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:vm="clr-namespace:QuanLyNhaHang.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="#F4F6F9"
             TextElement.FontFamily="Comfortaa">

    <UserControl.DataContext>
        <vm:MenuAdminViewModel />
    </UserControl.DataContext>

    <Grid x:Name="MainSec" Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6.5*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="3.5*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0 0 5 0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="20 20 20 15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#F1F5F9" CornerRadius="8" BorderThickness="1" BorderBrush="#E2E8F0" Padding="15 0" Height="45" Margin="0 0 20 0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <fa:IconImage Grid.Column="0" Icon="Search" Width="18" Height="18" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0 0 10 0"/>
                            <TextBox Grid.Column="1" FontSize="16" Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Tìm kiếm món ăn..." BorderThickness="0" Background="Transparent" 
                                     VerticalAlignment="Center" VerticalContentAlignment="Center" Foreground="#1E293B"
                                     materialDesign:TextFieldAssist.DecorationVisibility="Hidden"/>
                        </Grid>
                    </Border>

                    <Button Grid.Column="1" Background="#1C3879" Command="{Binding AddDishes_Command}" Foreground="White" BorderThickness="0"
                            Height="45" Width="130" materialDesign:ButtonAssist.CornerRadius="6" Cursor="Hand" Margin="0 0 15 0">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="Plus" Width="14" Height="14" Foreground="White" Margin="0 0 8 0"/>
                            <TextBlock Text="Thêm món" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2" Background="#EF4444" Command="{Binding RemoveDish_Command}" CommandParameter="{Binding ElementName=Dishes_ListView}"
                            Foreground="White" BorderThickness="0" Height="45" Width="130" materialDesign:ButtonAssist.CornerRadius="6" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="TrashCan" Width="14" Height="14" Foreground="White" Margin="0 0 8 0"/>
                            <TextBlock Text="Xóa món" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="#E2E8F0" Margin="20 0"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="15 10 15 15">
                    <ListView x:Name="Dishes_ListView" SelectedIndex="0" FontSize="15" BorderThickness="0" Background="Transparent"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ItemsSource="{Binding MenuItemCollection, UpdateSourceTrigger=PropertyChanged}"
                              SelectedItem="{Binding MenuItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                              IsSynchronizedWithCurrentItem="True" HorizontalContentAlignment="Stretch">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="5 8"/>
                                <Setter Property="Margin" Value="0 2"/>
                                <Setter Property="BorderThickness" Value="0 0 0 1"/>
                                <Setter Property="BorderBrush" Value="#F1F5F9"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="122" Header="Mã món">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ID}" FontWeight="Bold" Foreground="#64748B"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Width="200" Header="Tên món" DisplayMemberBinding="{Binding FoodName}"/>
                                <GridViewColumn Width="150" Header="Giá (VNĐ)">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding PriceVNDCurrency}" FontWeight="SemiBold" Foreground="#E63946" HorizontalAlignment="Right"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Width="200" Header="Thời gian nấu">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <fa:IconImage Icon="Clock" Width="14" Height="14" Foreground="#10B981" Margin="0 0 5 0"/>
                                                <TextBlock Text="{Binding CookingTime}" FontWeight="Bold" Foreground="#10B981"/>
                                                <TextBlock Text=" Phút" Foreground="#64748B" Margin="3 0 0 0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </ScrollViewer>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#E2E8F0" Margin="5 30" Cursor="SizeWE"/>

        <Border Grid.Column="2" Background="White" CornerRadius="12" Margin="5 0 0 0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid x:Name="EditGrid" Visibility="{Binding EditView}" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" HorizontalAlignment="Center" Margin="0 10 0 20">
                        <Border Width="180" Height="180" CornerRadius="12" Background="#F1F5F9" BorderThickness="2" BorderBrush="#E2E8F0" ClipToBounds="True">
                            <Image Source="{Binding MenuItem.FoodImage, UpdateSourceTrigger=PropertyChanged}" Stretch="Uniform"/>
                        </Border>
                        <Button Command="{Binding EditFoodImage_Command}" Background="#1C3879" Foreground="White" BorderThickness="0"
                                Width="40" Height="40" materialDesign:ButtonAssist.CornerRadius="20" Cursor="Hand"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0 0 -10 -10" Padding="0">
                            <Button.Effect>
                                <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.3"/>
                            </Button.Effect>
                            <fa:IconImage Icon="Camera" Width="18" Height="18" Foreground="White"/>
                        </Button>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Orientation="Vertical">
                            <Grid Margin="0 0 0 20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding MenuItem.ID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="True" FontSize="16" materialDesign:HintAssist.Hint="Mã món" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Foreground="#64748B"/>
                                <TextBox Grid.Column="2" Text="{Binding MenuItem.FoodName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="16" materialDesign:HintAssist.Hint="Tên món" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Foreground="#1E293B"/>
                            </Grid>

                            <Grid Margin="0 0 0 20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding MenuItem.Str_Price, Mode=TwoWay}"
                                         FontSize="16" materialDesign:HintAssist.Hint="Giá (VNĐ)" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Foreground="#1E293B"/>
                                <TextBox Grid.Column="2" Text="{Binding MenuItem.Str_CookingTime, Mode=TwoWay}"
                                         FontSize="16" materialDesign:HintAssist.Hint="Thời gian nấu (Phút)" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Foreground="#1E293B"/>
                            </Grid>

                            <Button Margin="0 10 0 20" Command="{Binding EditIngredient_Command}" Content="SỬA VÀ XEM NGUYÊN LIỆU"
                                    Background="#F1F5F9" Foreground="#1C3879" BorderThickness="0" Height="45" materialDesign:ButtonAssist.CornerRadius="6" FontWeight="Bold"/>

                            <Grid Margin="0 10 0 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Command="{Binding DiscardChanges_Command}" Content="Hủy thay đổi"
                                        Background="Transparent" Foreground="#64748B" BorderBrush="#CBD5E1" Height="45" materialDesign:ButtonAssist.CornerRadius="6"/>
                                <Button Grid.Column="2" Command="{Binding SaveChanges_Command}" Content="Lưu thay đổi"
                                        Background="#1C3879" Foreground="White" BorderThickness="0" Height="45" materialDesign:ButtonAssist.CornerRadius="6"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="AddGrid" Visibility="{Binding AddView}" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0 0 0 16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="ClipboardList" Width="18" Height="18" Foreground="#1C3879" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding AddDishStepTitle}" FontSize="16" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding AddDishStepDescription}" FontSize="12" Foreground="#64748B" Margin="0 6 0 4" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding ActiveAddDishSummary}" FontSize="12" FontWeight="SemiBold" Foreground="#1C3879"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid Visibility="{Binding AddDishInfoStepView}" FocusManager.FocusedElement="{Binding ElementName=AddDishIdTextBox}">
                                <StackPanel>
                                    <Grid HorizontalAlignment="Center" Margin="0 8 0 18">
                                        <Border Width="180" Height="180" CornerRadius="12" Background="#F1F5F9" BorderThickness="2" BorderBrush="#E2E8F0" ClipToBounds="True">
                                            <Image Source="{Binding AddItem.FoodImage}" Stretch="Uniform"/>
                                        </Border>
                                        <Button Command="{Binding AddImage_Command}" Background="#10B981" Foreground="White" BorderThickness="0"
                                                Width="40" Height="40" materialDesign:ButtonAssist.CornerRadius="20" Cursor="Hand"
                                                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0 0 -10 -10" Padding="0">
                                            <Button.Effect>
                                                <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.3"/>
                                            </Button.Effect>
                                            <fa:IconImage Icon="Camera" Width="18" Height="18" Foreground="White"/>
                                        </Button>
                                    </Grid>
                                    <Grid Margin="0 0 0 10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="15"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBox x:Name="AddDishIdTextBox"
                                                     Text="{Binding AddItem.ID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     IsReadOnly="{Binding IsAddDishInfoReadOnly}"
                                                     FontSize="16" materialDesign:HintAssist.Hint="Mã món"
                                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Foreground="#1E293B"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBox Text="{Binding AddItem.FoodName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     IsReadOnly="{Binding IsAddDishInfoReadOnly}"
                                                     FontSize="16" materialDesign:HintAssist.Hint="Tên món"
                                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Foreground="#1E293B"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0 0 0 18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="15"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBox Text="{Binding AddItem.Str_Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     IsReadOnly="{Binding IsAddDishInfoReadOnly}"
                                                     FontSize="16" materialDesign:HintAssist.Hint="Giá (VNĐ)"
                                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Foreground="#1E293B"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBox Text="{Binding AddItem.Str_CookingTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     IsReadOnly="{Binding IsAddDishInfoReadOnly}"
                                                     FontSize="16" materialDesign:HintAssist.Hint="Thời gian nấu (Phút)"
                                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Foreground="#1E293B"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="15"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Command="{Binding SwitchToEditView_Command}"
                                                Content="Chuyển sang Chỉnh sửa" Background="Transparent" Foreground="#64748B" BorderBrush="#CBD5E1" Height="45" materialDesign:ButtonAssist.CornerRadius="6"/>
                                        <Button Grid.Column="2" Command="{Binding SaveAndGoToRecipe_Command}"
                                                Content="{Binding SaveAndGoToRecipeButtonText}" Background="#10B981" Foreground="White" BorderThickness="0" Height="45" materialDesign:ButtonAssist.CornerRadius="6" FontWeight="Bold"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <Grid Visibility="{Binding AddDishRecipeStepView}" FocusManager.FocusedElement="{Binding ElementName=RecipeSearchTextBox}">
                                <StackPanel>
                                    <Border Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0 0 0 14">
                                        <StackPanel Orientation="Horizontal">
                                            <fa:IconImage Icon="CircleInfo" Width="15" Height="15" Foreground="#EA580C" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Thêm nguyên liệu bằng nút 'Thêm vào công thức' hoặc double-click vào nguyên liệu." FontSize="12" Foreground="#9A3412" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0 0 0 14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="RecipeSearchTextBox" Grid.Column="0" Text="{Binding IngreFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     materialDesign:HintAssist.Hint="Tìm nguyên liệu..." Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="15"/>
                                            <Button Grid.Column="2" Command="{Binding AddIngredientsToDish_Command}" CommandParameter="{Binding Selected_Ingredient}"
                                                    Content="Thêm vào công thức" Background="#1C3879" Foreground="White" BorderThickness="0"
                                                    Height="42" Padding="14 0" materialDesign:ButtonAssist.CornerRadius="6"/>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="Nguyên liệu trong kho" FontSize="13" FontWeight="SemiBold" Foreground="#475569" Margin="0 0 0 6"/>
                                    <ListView Height="170" ItemsSource="{Binding IngredientCollection, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedItem="{Binding Selected_Ingredient}" BorderBrush="#E2E8F0" BorderThickness="1"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListView.InputBindings>
                                            <MouseBinding Gesture="LeftDoubleClick" Command="{Binding QuickAddIngredient_Command}" CommandParameter="{Binding Selected_Ingredient}"/>
                                        </ListView.InputBindings>
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Nguyên liệu" Width="170" DisplayMemberBinding="{Binding TenSanPham}"/>
                                                <GridViewColumn Header="Tồn" Width="60" DisplayMemberBinding="{Binding TonDu}"/>
                                                <GridViewColumn Header="Đơn vị" Width="70" DisplayMemberBinding="{Binding DonVi}"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>

                                    <TextBlock Text="Công thức món đang tạo" FontSize="13" FontWeight="SemiBold" Foreground="#475569" Margin="0 14 0 6"/>
                                    <ItemsControl ItemsSource="{Binding Ingredients_ForDishes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderThickness="1" BorderBrush="#E2E8F0" CornerRadius="6" Padding="8" Margin="0 0 0 8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding TenNL}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#1E293B"/>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10 0 0 0">
                                                            <Button Width="28" Height="28" BorderBrush="#CBD5E1" Background="White"
                                                                    Command="{Binding DataContext.DecreaseIngredientQuantity_Command, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                                    CommandParameter="{Binding}" Content="-" />
                                                            <TextBox Text="{Binding SoLuong, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="52" Height="28"
                                                                     HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="5 0"/>
                                                            <Button Width="28" Height="28" BorderBrush="#CBD5E1" Background="White"
                                                                    Command="{Binding DataContext.IncreaseIngredientQuantity_Command, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                                    CommandParameter="{Binding}" Content="+"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="2" Margin="10 0 0 0" Width="32" Height="32"
                                                                Background="Transparent" BorderThickness="0"
                                                                Command="{Binding DataContext.RemoveIngredientFromDish_Command, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                                CommandParameter="{Binding}">
                                                            <fa:IconImage Icon="TrashCan" Width="14" Height="14" Foreground="#EF4444"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="15"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Command="{Binding BackToDishInfo_Command}" Content="Quay lại bước 1"
                                                Background="Transparent" Foreground="#64748B" BorderBrush="#CBD5E1" Height="45" materialDesign:ButtonAssist.CornerRadius="6"/>
                                        <Button Grid.Column="2" Command="{Binding FinishCreateDish_Command}" Content="Hoàn tất tạo món"
                                                Background="#10B981" Foreground="White" BorderThickness="0" Height="45" materialDesign:ButtonAssist.CornerRadius="6" FontWeight="Bold"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
