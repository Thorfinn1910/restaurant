<UserControl x:Class="QuanLyNhaHang.View.LichSuBan"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity" 
             xmlns:i1="clr-namespace:Microsoft.VisualBasic;assembly=Microsoft.VisualBasic.Core"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:local="clr-namespace:QuanLyNhaHang.View" 
             xmlns:vm="clr-namespace:QuanLyNhaHang.ViewModel"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1100"
             x:Name="mainPage"
             FontSize="15"
             FontFamily="Comfortaa"
             Background="#F4F6F9"> <UserControl.DataContext>
        <vm:LichSuBanViewModel />
    </UserControl.DataContext>

    <Grid Margin="15">
        <Border Background="White" CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.1" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="20 20 20 15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>    <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0 0 20 0">
                        <fa:IconImage Icon="Search" Width="18" Height="18" Foreground="#94A3B8" Margin="0 0 10 5" VerticalAlignment="Bottom"/>
                        <TextBox x:Name="FilterBox" 
                                 Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Tìm kiếm tên sản phẩm..."
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 FontSize="16" Height="45" Width="280" AllowDrop="True" Foreground="#1E293B"/>
                    </StackPanel>

                    <ComboBox Grid.Column="1" x:Name="Filterbox"
                              SelectedItem="{Binding SelectedItemFilter}" 
                              SelectionChanged="Filterbox_SelectionChanged"
                              materialDesign:HintAssist.Hint="Lọc theo"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                              Height="45" Width="130" Margin="0 0 15 0" FontSize="15" SelectedIndex="1">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectionChanged">
                                <i:InvokeCommandAction Command="{Binding CheckItemFilterCM}" CommandParameter="{Binding ElementName=Filterbox}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <ComboBoxItem Content="Toàn bộ" />
                        <ComboBoxItem Content="Theo ngày" />
                        <ComboBoxItem Content="Theo tháng" />
                    </ComboBox>

                    <Grid Grid.Column="2" Margin="0 0 20 0" VerticalAlignment="Bottom">
                        <ComboBox x:Name="cbbmonth" SelectedIndex="{Binding SelectedMonth, Mode=TwoWay}"
                                  Visibility="Collapsed" Height="45" Width="130" FontSize="15"
                                  materialDesign:HintAssist.Hint="Chọn tháng" Style="{StaticResource MaterialDesignFloatingHintComboBox}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="SelectionChanged">
                                    <i:InvokeCommandAction Command="{Binding SelectedMonthCM}" CommandParameter="{Binding ElementName=cbbmonth}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                            <ComboBoxItem Content="Tháng 1" />
                            <ComboBoxItem Content="Tháng 2" />
                            <ComboBoxItem Content="Tháng 3" />
                            <ComboBoxItem Content="Tháng 4" />
                            <ComboBoxItem Content="Tháng 5" />
                            <ComboBoxItem Content="Tháng 6" />
                            <ComboBoxItem Content="Tháng 7" />
                            <ComboBoxItem Content="Tháng 8" />
                            <ComboBoxItem Content="Tháng 9" />
                            <ComboBoxItem Content="Tháng 10" />
                            <ComboBoxItem Content="Tháng 11" />
                            <ComboBoxItem Content="Tháng 12" />
                        </ComboBox>

                        <DatePicker x:Name="timepicker" SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                                    Visibility="Visible" Height="45" Width="130" FontSize="15"
                                    materialDesign:HintAssist.Hint="Chọn ngày" Style="{StaticResource MaterialDesignFloatingHintDatePicker}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="SelectedDateChanged">
                                    <i:InvokeCommandAction Command="{Binding SelectedDateExportListCM}" CommandParameter="{Binding ElementName=timepicker}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </DatePicker>
                    </Grid>

                    <Button Grid.Column="3" Command="{Binding ExportFileCM}" 
                            Height="42" Width="140" Background="#10B981" Foreground="White" BorderThickness="0" Cursor="Hand" 
                            materialDesign:ButtonAssist.CornerRadius="6" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="FileExcel" Width="16" Height="16" Foreground="White" Margin="0 0 8 0" VerticalAlignment="Center"/>
                            <TextBlock Text="Xuất Excel" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="#E2E8F0" Margin="20 0"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="15 10 15 15">
                    <ListView ItemsSource="{Binding ListProduct}" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="5 10"/>
                                <Setter Property="Margin" Value="0 2"/>
                                <Setter Property="BorderThickness" Value="0 0 0 1"/>
                                <Setter Property="BorderBrush" Value="#F1F5F9"/>
                                <Setter Property="FontSize" Value="15"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="180" Header="Số hóa đơn">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SoHD}" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn DisplayMemberBinding="{Binding TenMon}" Width="300" Header="Tên sản phẩm" />

                                <GridViewColumn Width="120" Header="Số lượng">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SoLuong}" FontWeight="Bold" Foreground="#1C3879" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Width="180" Header="Thành tiền (VNĐ)">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TriGia}" FontWeight="SemiBold" Foreground="#E63946" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn DisplayMemberBinding="{Binding ngayHD}" Width="200" Header="Ngày tạo hóa đơn" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </ScrollViewer>

            </Grid>
        </Border>
    </Grid>
</UserControl>