<UserControl x:Class="QuanLyNhaHang.View.Menu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             xmlns:nav="clr-namespace:QuanLyNhaHang.State.Navigator"
             xmlns:vm="clr-namespace:QuanLyNhaHang.ViewModel"
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="#F4F6F9"
             TextElement.FontFamily="Comfortaa"
             x:Name="page">

    <UserControl.DataContext>
        <vm:MenuViewModel x:Name="vm"/>
    </UserControl.DataContext>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6.5*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="3.5*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0 0 5 0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="20 20 20 15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0 0 0 5">
                        <TextBlock Text="Sắp xếp theo:" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center" Margin="0 0 10 0" FontSize="15"/>
                        <ComboBox ItemsSource="{Binding ComboBox_2Items}" SelectedItem="{Binding MyComboboxSelection, Mode=TwoWay}"
                                  Width="130" Height="35" FontSize="15" VerticalContentAlignment="Center"
                                  Style="{StaticResource MaterialDesignComboBox}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="SelectionChanged">
                                    <i:InvokeCommandAction Command="{Binding SortingFeature_Command}"/>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </ComboBox>
                    </StackPanel>

                    <Border Grid.Column="2" Background="#F1F5F9" CornerRadius="8" BorderThickness="1" BorderBrush="#E2E8F0" Padding="15 0" Height="45" VerticalAlignment="Bottom">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <fa:IconImage Grid.Column="0" Icon="Search" Width="18" Height="18" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0 0 10 0"/>

                            <TextBox Grid.Column="1" x:Name="txtInput" materialDesign:HintAssist.Hint="Tìm kiếm món ăn..." 
                                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="200" FontSize="16" BorderThickness="0" Background="Transparent" 
                                     VerticalAlignment="Center" VerticalContentAlignment="Center" Foreground="#1E293B"
                                     Style="{StaticResource MaterialDesignTextBox}"
                                     materialDesign:TextFieldAssist.DecorationVisibility="Hidden"/>
                        </Grid>
                    </Border>
                </Grid>

                <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="#E2E8F0" Margin="20 0"/>

                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Margin="10">
                    <ItemsControl x:Name="itemControl" ItemsSource="{Binding MenuItemCollection, UpdateSourceTrigger=PropertyChanged}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="12" Width="180" Height="250" Margin="10" BorderThickness="1" BorderBrush="#E2E8F0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.05" Color="#000000"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="120"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0" CornerRadius="12 12 0 0" Background="#F1F5F9" ClipToBounds="True">
                                            <Image Source="{Binding FoodImage}" Stretch="UniformToFill" />
                                        </Border>

                                        <StackPanel Grid.Row="1" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10">
                                            <TextBlock Text="{Binding FoodName}" FontWeight="Bold" FontSize="16" Foreground="#1E293B" TextAlignment="Center" TextWrapping="Wrap" MaxHeight="45"/>
                                            <TextBlock Text="{Binding PriceVNDCurrency}" FontWeight="SemiBold" FontSize="15" Foreground="#E63946" TextAlignment="Center" Margin="0 5 0 0"/>
                                        </StackPanel>

                                        <Button Grid.Row="2" Command="{Binding ElementName=vm, Path=OrderFeature_Command}" CommandParameter="{Binding}"
                                                Background="#10B981" Foreground="White" BorderThickness="0" Height="35" Margin="15 0 15 15" Cursor="Hand" materialDesign:ButtonAssist.CornerRadius="6">
                                            <StackPanel Orientation="Horizontal">
                                                <fa:IconImage Icon="CartPlus" Width="14" Height="14" Foreground="White" Margin="0 0 5 0"/>
                                                <TextBlock Text="ĐẶT MÓN" FontSize="14" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#E2E8F0" Margin="5 30" Cursor="SizeWE"/>

        <Border Grid.Column="2" Background="White" CornerRadius="12" Margin="5 0 0 0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1C3879" CornerRadius="12 12 0 0" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="ORDER MỚI" Foreground="White" FontWeight="Bold" FontSize="20"/>
                            <TextBlock Text="{Binding Day}" Foreground="#CBD5E1" FontSize="14" Margin="0 5 0 0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Bàn" Foreground="White" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0 0 10 0"/>
                            <ComboBox ItemsSource="{Binding Tables}" SelectedItem="{Binding SelectedTable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      DisplayMemberPath="NumOfTable" Background="White" Foreground="#1E293B" Width="80" Height="35" FontSize="16"
                                      HorizontalContentAlignment="Center" VerticalContentAlignment="Center" BorderThickness="0"
                                      materialDesign:TextFieldAssist.DecorationVisibility="Hidden">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Margin" Value="2"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="0">
                                                <Setter Property="Background" Value="#EF4444"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="1">
                                                <Setter Property="Background" Value="#10B981"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="15 10">
                    <StackPanel Orientation="Vertical" x:Name="border">
                        <ItemsControl ItemsSource="{Binding SelectedItems, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderThickness="0 0 0 1" BorderBrush="#E2E8F0" Padding="5 10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0" Command="{Binding ElementName=vm, Path=RemoveItemFeature_Command}" CommandParameter="{Binding}"
                                                    Background="Transparent" BorderThickness="0" Width="30" Height="30" Padding="0" Cursor="Hand" Margin="0 0 10 0">
                                                <fa:IconImage Icon="TrashCan" Foreground="#EF4444" Height="16" Width="16" />
                                            </Button>

                                            <TextBlock Grid.Column="1" Text="{Binding FoodName}" FontWeight="SemiBold" FontSize="15" Foreground="#1E293B" VerticalAlignment="Center" TextWrapping="Wrap"/>

                                            <Border Grid.Column="2" Background="#F1F5F9" CornerRadius="4" Padding="8 2" Margin="10 0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Quantity}" FontWeight="Bold" FontSize="14" Foreground="#1C3879"/>
                                            </Border>

                                            <TextBlock Grid.Column="3" Text="{Binding PriceVNDCurrency}" FontWeight="SemiBold" FontSize="15" Foreground="#E63946" VerticalAlignment="Center" TextAlignment="Right" Width="80"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="2" Background="#F8FAFC">
                    <Border CornerRadius="0 0 12 12" Background="Transparent">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0 0 0 20">
                                <TextBlock Text="TỔNG CỘNG" FontSize="18" FontWeight="Bold" Foreground="#64748B" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Path=StrSubtotal}" FontSize="26" FontWeight="Bold" Foreground="#E63946" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Command="{Binding ClearAllSelectedDishes}" Background="White" Foreground="#EF4444" BorderBrush="#EF4444" BorderThickness="1"
                                        Height="45" materialDesign:ButtonAssist.CornerRadius="8" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <fa:IconImage Icon="Trash" Width="14" Height="14" Foreground="#EF4444" Margin="0 0 8 0"/>
                                        <TextBlock Text="Xóa hết" FontSize="15" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>

                                <Button Grid.Column="2" Command="{Binding Inform_Chef_Of_OrderedDishes}" Background="#1C3879" Foreground="White" BorderThickness="0"
                                        Height="45" materialDesign:ButtonAssist.CornerRadius="8" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <fa:IconImage Icon="BellConcierge" Width="18" Height="18" Foreground="White" Margin="0 0 10 0"/>
                                        <TextBlock Text="BÁO CHẾ BIẾN" FontSize="16" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</UserControl>