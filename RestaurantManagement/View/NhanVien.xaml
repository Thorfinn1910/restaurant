<UserControl x:Class="QuanLyNhaHang.View.NhanVien"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:local="clr-namespace:QuanLyNhaHang.View"
             mc:Ignorable="d" 
             TextElement.FontFamily="Comfortaa"
             TextElement.FontSize="15"
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="#F4F6F9">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0 0 10 0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="20 25 20 15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#F1F5F9" CornerRadius="8" BorderThickness="1" BorderBrush="#E2E8F0" Padding="15 0" Height="45" Margin="0 0 20 0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <fa:IconImage Grid.Column="0" Icon="Search" Width="18" Height="18" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0 0 10 0"/>
                            <TextBox Grid.Column="1" Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                                     Foreground="#1E293B" FontSize="16" BorderThickness="0" Background="Transparent" VerticalAlignment="Center"
                                     materialDesign:HintAssist.Hint="Tìm kiếm nhân viên..." materialDesign:TextFieldAssist.DecorationVisibility="Hidden"/>
                        </Grid>
                    </Border>

                    <Button Name="btnCheckStaff" Grid.Column="1" Command="{Binding CheckCM}" Click="btnCheckStaff_Click"
                            Background="#F97316" Foreground="White" BorderThickness="0" Cursor="Hand" Height="45" Width="140" 
                            Margin="0 0 10 0" materialDesign:ButtonAssist.CornerRadius="6" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="ClipboardUser" Width="16" Height="16" Foreground="White" Margin="0 0 8 0"/>
                            <TextBlock Text="Chấm công" VerticalAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <Button Name="btnDeleteStaff" Grid.Column="2" Command="{Binding DeleteCM}" Click="btnDeleteStaff_Click"
                            Background="#EF4444" Foreground="White" BorderThickness="0" Cursor="Hand" Height="45" Width="90" 
                            materialDesign:ButtonAssist.CornerRadius="6" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="TrashCan" Width="16" Height="16" Foreground="White" Margin="0 0 8 0"/>
                            <TextBlock Text="Xóa" VerticalAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="#E2E8F0" Margin="20 0"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="15 10 15 15">
                    <ListView ItemsSource="{Binding ListStaff}" SelectedItem="{Binding Selected, Mode=OneWayToSource}"
                              FontSize="15" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch"
                              IsSynchronizedWithCurrentItem="True">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="5 10"/>
                                <Setter Property="Margin" Value="0 2"/>
                                <Setter Property="BorderThickness" Value="0 0 0 1"/>
                                <Setter Property="BorderBrush" Value="#F1F5F9"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn DisplayMemberBinding="{Binding HoTen}" Width="260">
                                    <GridViewColumn.Header>
                                        <TextBlock Text="Họ Tên" FontWeight="Bold" Foreground="#64748B"/>
                                    </GridViewColumn.Header>
                                </GridViewColumn>

                                <GridViewColumn Width="150" Header="Chức vụ">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ChucVu}" FontWeight="SemiBold" Foreground="#1C3879"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn DisplayMemberBinding="{Binding NgayVaoLam}" Width="160" Header="Ngày vào làm" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="12" Margin="10 0 0 0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
            </Border.Effect>

            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0 0 0 20" Orientation="Horizontal">
                    <fa:IconImage Icon="UserEdit" Width="22" Height="22" Foreground="#1C3879" Margin="0 0 10 0" VerticalAlignment="Center"/>
                    <TextBlock Text="HỒ SƠ NHÂN VIÊN" FontSize="18" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                </StackPanel>

                <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="#E2E8F0" Margin="0"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0 15 0 0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Row="0" Grid.Column="0" materialDesign:HintAssist.Hint="Mã NV" Margin="0 10 0 20"
                                 Text="{Binding ID, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Height="45"/>
                        <TextBox Grid.Row="0" Grid.Column="2" materialDesign:HintAssist.Hint="Họ và Tên" Margin="0 10 0 20"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Height="45"/>

                        <ComboBox Grid.Row="1" Grid.Column="0" materialDesign:HintAssist.Hint="Chức vụ" Margin="0 10 0 20"
                                  Text="{Binding Position, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintComboBox}" Height="45">
                            <ComboBoxItem>Quản lý</ComboBoxItem>
                            <ComboBoxItem>Bếp trưởng</ComboBoxItem>
                            <ComboBoxItem>Phụ bếp</ComboBoxItem>
                            <ComboBoxItem>Order</ComboBoxItem>
                            <ComboBoxItem>Bảo vệ</ComboBoxItem>
                            <ComboBoxItem>Shipper</ComboBoxItem>
                        </ComboBox>
                        <ComboBox Grid.Row="1" Grid.Column="2" materialDesign:HintAssist.Hint="Hình thức" Margin="0 10 0 20"
                                  Text="{Binding Fulltime, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintComboBox}" Height="45">
                            <ComboBoxItem IsSelected="True">Full-time</ComboBoxItem>
                            <ComboBoxItem>Part-time</ComboBoxItem>
                        </ComboBox>

                        <TextBox Grid.Row="2" Grid.Column="0" materialDesign:HintAssist.Hint="Số điện thoại" Margin="0 10 0 20"
                                 Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Height="45"/>
                        <DatePicker Grid.Row="2" Grid.Column="2" materialDesign:HintAssist.Hint="Ngày sinh" Margin="0 10 0 20"
                                    SelectedDate="{Binding DateBorn, Mode=TwoWay, ValidatesOnDataErrors=False, UpdateSourceTrigger=PropertyChanged}"
                                    Style="{StaticResource MaterialDesignFloatingHintDatePicker}" Height="45"/>

                        <TextBox Grid.Row="3" Grid.Column="0" materialDesign:HintAssist.Hint="Địa chỉ" Margin="0 10 0 20"
                                 Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Height="45"/>
                        <DatePicker Grid.Row="3" Grid.Column="2" materialDesign:HintAssist.Hint="Ngày vào làm" Margin="0 10 0 20"
                                    SelectedDate="{Binding DateStartWork, Mode=TwoWay, ValidatesOnDataErrors=False, UpdateSourceTrigger=PropertyChanged}"
                                    Style="{StaticResource MaterialDesignFloatingHintDatePicker}" Height="45"/>

                        <TextBox Grid.Row="4" Grid.Column="0" materialDesign:HintAssist.Hint="Tên đăng nhập" Margin="0 10 0 20"
                                 Text="{Binding Account, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Height="45"/>
                        <TextBox Grid.Row="4" Grid.Column="2" materialDesign:HintAssist.Hint="Mật khẩu" Margin="0 10 0 20"
                                 Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Height="45"/>
                    </Grid>
                </ScrollViewer>

                <Button Name="btnEditStaff" Grid.Row="2" Command="{Binding EditCM}" 
                        Background="#10B981" Foreground="White" BorderThickness="0" Cursor="Hand" Height="50" Margin="0 10 0 0"
                        materialDesign:ButtonAssist.CornerRadius="8">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="Save" Width="18" Height="18" Foreground="White" Margin="0 0 10 0"/>
                        <TextBlock Text="CẬP NHẬT THÔNG TIN" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </Grid>
        </Border>
    </Grid>
</UserControl>