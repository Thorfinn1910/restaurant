<UserControl x:Class="QuanLyNhaHang.View.Kho"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:local="clr-namespace:QuanLyNhaHang.View"
             mc:Ignorable="d" 
             TextElement.FontFamily="Comfortaa"
             TextElement.FontSize="15"
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="#F4F6F9">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6.5*"/>
            <ColumnDefinition Width="3.5*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0 0 10 0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="20 25 20 15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Name="txtSearch" Grid.Column="0" Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#1E293B" FontSize="16" Height="45" Margin="0 0 20 0"
                             materialDesign:HintAssist.Hint="Tìm kiếm sản phẩm..."
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" VerticalAlignment="Bottom"/>

                    <Button Name="btnCheckWareHouse" Grid.Column="1" Command="{Binding CheckCM}"
                            Background="#1C3879" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Height="40" Width="110" Margin="0 0 10 0" materialDesign:ButtonAssist.CornerRadius="6" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="ClipboardCheck" Width="16" Height="16" Foreground="White" Margin="0 0 8 0"/>
                            <TextBlock Text="Kiểm tra" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Name="btnDeleteWareHouse" Grid.Column="2" Command="{Binding DeleteCM}"
                            Background="#EF4444" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Height="40" Width="90" materialDesign:ButtonAssist.CornerRadius="6" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="Trash" Width="16" Height="16" Foreground="White" Margin="0 0 8 0"/>
                            <TextBlock Text="Xóa" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="#E2E8F0" Margin="20 0"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="15 10 15 15">
                    <ListView ItemsSource="{Binding ListWareHouse}" SelectedItem="{Binding Selected, Mode=OneWayToSource}"
                              FontSize="15" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="5 8"/>
                                <Setter Property="Margin" Value="0 2"/>
                                <Setter Property="BorderThickness" Value="0 0 0 1"/>
                                <Setter Property="BorderBrush" Value="#F1F5F9"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn DisplayMemberBinding="{Binding TenSanPham}" Width="260" Header="Tên sản phẩm" />
                                <GridViewColumn Width="112" Header="Tồn dư">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TonDu}" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn DisplayMemberBinding="{Binding DonVi}" Width="108" Header="Đơn vị" />
                                <GridViewColumn Width="160" Header="Đơn giá">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DonGia}" FontWeight="SemiBold" Foreground="#E63946" HorizontalAlignment="Right"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="12" Margin="10 0 0 0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
            </Border.Effect>

            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0 0 0 20">
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 15">
                        <fa:IconImage Icon="BoxOpen" Width="22" Height="22" Foreground="#1C3879" Margin="0 0 10 0"/>
                        <TextBlock Text="THÔNG TIN NHẬP KHO" FontSize="18" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="{Binding CurrentStockFormModeKey}" FontSize="12" FontWeight="Bold" Foreground="#1C3879"/>
                    <TextBlock Text="{Binding CurrentStockFormModeDescription}" FontSize="12" Foreground="#64748B" Margin="0 4 0 10"/>

                    <ComboBox materialDesign:HintAssist.Hint="Phiếu nhập gần đây (chọn để sửa)"
                              ItemsSource="{Binding ListIn}" SelectedItem="{Binding SelectedInputHistory, Mode=TwoWay}"
                              IsEnabled="{Binding CanSelectHistory}"
                              DisplayMemberPath="HistoryDisplay"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}" FontSize="15" Height="45"/>
                </StackPanel>

                <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="#E2E8F0" Margin="0"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0 15 0 0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Row="0" Grid.Column="0" materialDesign:HintAssist.Hint="Mã nhập" Margin="0 10 0 15"
                                 Text="{Binding ID, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Height="45"/>
                        <TextBox Grid.Row="0" Grid.Column="2" materialDesign:HintAssist.Hint="Tên sản phẩm" Margin="0 10 0 15"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Height="45"/>

                        <TextBox Grid.Row="1" Grid.Column="0" materialDesign:HintAssist.Hint="Số lượng" Margin="0 10 0 15"
                                 Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Height="45"/>
                        <DatePicker Grid.Row="1" Grid.Column="2" materialDesign:HintAssist.Hint="Ngày nhập" Margin="0 10 0 15"
                                    SelectedDate="{Binding DateIn, Mode=TwoWay, ValidatesOnDataErrors=False, UpdateSourceTrigger=PropertyChanged}"
                                    Style="{StaticResource MaterialDesignFloatingHintDatePicker}" Height="45"/>

                        <TextBox Grid.Row="2" Grid.Column="0" materialDesign:HintAssist.Hint="Giá nhập" Margin="0 10 0 15"
                                 Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Height="45"/>
                        <ComboBox Grid.Row="2" Grid.Column="2" materialDesign:HintAssist.Hint="Đơn vị" Margin="0 10 0 15"
                                  SelectedValue="{Binding Unit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}" Height="45">
                            <ComboBoxItem>Kg</ComboBoxItem>
                            <ComboBoxItem>Chai</ComboBoxItem>
                            <ComboBoxItem>Quả</ComboBoxItem>
                            <ComboBoxItem>Gói</ComboBoxItem>
                            <ComboBoxItem>Con</ComboBoxItem>
                            <ComboBoxItem>Lát</ComboBoxItem>
                            <ComboBoxItem>Cây</ComboBoxItem>
                            <ComboBoxItem>Lon</ComboBoxItem>
                            <ComboBoxItem>Bó</ComboBoxItem>
                        </ComboBox>

                        <TextBox Grid.Row="3" Grid.Column="0" materialDesign:HintAssist.Hint="Nguồn nhập" Margin="0 10 0 15"
                                 Text="{Binding Suplier, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Height="45"/>
                        <TextBox Grid.Row="3" Grid.Column="2" materialDesign:HintAssist.Hint="Liên lạc" Margin="0 10 0 15"
                                 Text="{Binding SuplierInfo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Height="45"/>
                    </Grid>
                </ScrollViewer>

                <Grid Grid.Row="2" Margin="0 10 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Name="btnCreateIngredientMode" Command="{Binding CreateNewIngredientCM}"
                            ToolTip="Tạo và khai báo một nguyên liệu hoàn toàn mới trong hệ thống"
                            Background="#0EA5E9" Foreground="White" BorderThickness="0" Cursor="Hand" Height="50"
                            materialDesign:ButtonAssist.CornerRadius="8">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="BoxOpen" Width="18" Height="18" Foreground="White" Margin="0 0 10 0"/>
                            <TextBlock Text="THÊM NGUYÊN LIỆU MỚI" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2" Name="btnAddStockIn" Command="{Binding AddCM}"
                            ToolTip="Lưu các thông tin trên và tạo một phiếu nhập hàng mới"
                            Background="#1C3879" Foreground="White" BorderThickness="0" Cursor="Hand" Height="50"
                            materialDesign:ButtonAssist.CornerRadius="8">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="Plus" Width="18" Height="18" Foreground="White" Margin="0 0 10 0"/>
                            <TextBlock Text="THÊM PHIẾU NHẬP" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4" Name="btnEditStockIn" Command="{Binding EditCM}"
                            ToolTip="Cập nhật những thay đổi vừa chỉnh sửa cho phiếu nhập đang chọn"
                            Background="#10B981" Foreground="White" BorderThickness="0" Cursor="Hand" Height="50"
                            materialDesign:ButtonAssist.CornerRadius="8">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="Edit" Width="18" Height="18" Foreground="White" Margin="0 0 10 0"/>
                            <TextBlock Text="SỬA PHIẾU ĐÃ CHỌN" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</UserControl>