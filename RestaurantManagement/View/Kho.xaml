<UserControl x:Class="QuanLyNhaHang.View.Kho"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:local="clr-namespace:QuanLyNhaHang.View"
             mc:Ignorable="d" 
             TextElement.FontFamily="Comfortaa"
             TextElement.FontSize="15"
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="#F4F6F9">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6.5*"/>
            <ColumnDefinition Width="3.5*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0 0 10 0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="20 25 20 15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Name="txtSearch" Grid.Column="0" Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#1E293B" FontSize="16" Height="45" Margin="0 0 20 0"
                             materialDesign:HintAssist.Hint="Tìm kiếm sản phẩm..."
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" VerticalAlignment="Bottom"/>

                    <Button Name="btnCheckWareHouse" Grid.Column="1" Command="{Binding CheckCM}"
                            Background="#1C3879" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Height="40" Width="110" Margin="0 0 10 0" materialDesign:ButtonAssist.CornerRadius="6" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="ClipboardCheck" Width="16" Height="16" Foreground="White" Margin="0 0 8 0"/>
                            <TextBlock Text="Kiểm tra" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Name="btnDeleteWareHouse" Grid.Column="2" Command="{Binding DeleteCM}"
                            Background="#EF4444" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Height="40" Width="90" materialDesign:ButtonAssist.CornerRadius="6" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="Trash" Width="16" Height="16" Foreground="White" Margin="0 0 8 0"/>
                            <TextBlock Text="Xóa" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="#E2E8F0" Margin="20 0"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="15 10 15 15">
                    <ListView ItemsSource="{Binding ListWareHouse}" SelectedItem="{Binding Selected, Mode=OneWayToSource}"
                              FontSize="15" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="5 8"/>
                                <Setter Property="Margin" Value="0 2"/>
                                <Setter Property="BorderThickness" Value="0 0 0 1"/>
                                <Setter Property="BorderBrush" Value="#F1F5F9"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn DisplayMemberBinding="{Binding TenSanPham}" Width="260" Header="Tên sản phẩm" />
                                <GridViewColumn Width="112" Header="Tồn dư">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TonDu}" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn DisplayMemberBinding="{Binding DonVi}" Width="108" Header="Đơn vị" />
                                <GridViewColumn Width="160" Header="Đơn giá">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DonGia}" FontWeight="SemiBold" Foreground="#E63946" HorizontalAlignment="Right"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="12" Margin="10 0 0 0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
            </Border.Effect>

            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0 0 0 12">
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                        <fa:IconImage Icon="BoxOpen" Width="22" Height="22" Foreground="#1C3879" Margin="0 0 10 0"/>
                        <TextBlock Text="THÔNG TIN NHẬP KHO" FontSize="18" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Chọn đúng tab nghiệp vụ để giảm thao tác và tránh nhập sai." FontSize="12" Foreground="#64748B"/>
                </StackPanel>

                <TabControl Grid.Row="1" SelectedIndex="{Binding CurrentStockTabIndex, Mode=TwoWay}">
                    <TabItem Header="Nguyên liệu mới">
                        <Grid Margin="8" FocusManager.FocusedElement="{Binding ElementName=NewIngredientIdBox}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBox x:Name="NewIngredientIdBox" materialDesign:HintAssist.Hint="Mã nhập" Text="{Binding ID, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 8 0 0"/>

                                    <TextBox materialDesign:HintAssist.Hint="Tên sản phẩm mới" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 8 0 0"/>

                                    <TextBox materialDesign:HintAssist.Hint="Số lượng" Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 8 0 0"/>

                                    <TextBox materialDesign:HintAssist.Hint="Giá nhập" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 8 0 0"/>

                                    <ComboBox materialDesign:HintAssist.Hint="Đơn vị" SelectedValue="{Binding Unit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" Style="{StaticResource MaterialDesignFloatingHintComboBox}" Margin="0 8 0 0">
                                        <ComboBoxItem>Kg</ComboBoxItem>
                                        <ComboBoxItem>Chai</ComboBoxItem>
                                        <ComboBoxItem>Quả</ComboBoxItem>
                                        <ComboBoxItem>Gói</ComboBoxItem>
                                        <ComboBoxItem>Con</ComboBoxItem>
                                        <ComboBoxItem>Lát</ComboBoxItem>
                                        <ComboBoxItem>Cây</ComboBoxItem>
                                        <ComboBoxItem>Lon</ComboBoxItem>
                                        <ComboBoxItem>Bó</ComboBoxItem>
                                    </ComboBox>

                                    <DatePicker materialDesign:HintAssist.Hint="Ngày nhập" SelectedDate="{Binding DateIn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintDatePicker}" Margin="0 8 0 0"/>

                                    <TextBox materialDesign:HintAssist.Hint="Nguồn nhập" Text="{Binding Suplier, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 8 0 0"/>
                                    <TextBox materialDesign:HintAssist.Hint="Liên lạc" Text="{Binding SuplierInfo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 8 0 0"/>
                                </StackPanel>
                            </ScrollViewer>
                            <Button Grid.Row="1" Command="{Binding AddCM}" Margin="0 12 0 0" Height="46" Background="#0EA5E9" Foreground="White" BorderThickness="0" materialDesign:ButtonAssist.CornerRadius="8">
                                <TextBlock Text="LƯU NGUYÊN LIỆU MỚI" FontWeight="Bold"/>
                            </Button>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Nhập bổ sung">
                        <Grid Margin="8" FocusManager.FocusedElement="{Binding ElementName=StockInIdBox}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBox x:Name="StockInIdBox" materialDesign:HintAssist.Hint="Mã nhập" Text="{Binding ID, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 8 0 0"/>

                                    <TextBox materialDesign:HintAssist.Hint="Tên sản phẩm" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 8 0 0"/>

                                    <TextBox materialDesign:HintAssist.Hint="Số lượng" Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 8 0 0"/>

                                    <TextBox materialDesign:HintAssist.Hint="Giá nhập" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 8 0 0"/>

                                    <ComboBox materialDesign:HintAssist.Hint="Đơn vị" SelectedValue="{Binding Unit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" Style="{StaticResource MaterialDesignFloatingHintComboBox}" Margin="0 8 0 0">
                                        <ComboBoxItem>Kg</ComboBoxItem>
                                        <ComboBoxItem>Chai</ComboBoxItem>
                                        <ComboBoxItem>Quả</ComboBoxItem>
                                        <ComboBoxItem>Gói</ComboBoxItem>
                                        <ComboBoxItem>Con</ComboBoxItem>
                                        <ComboBoxItem>Lát</ComboBoxItem>
                                        <ComboBoxItem>Cây</ComboBoxItem>
                                        <ComboBoxItem>Lon</ComboBoxItem>
                                        <ComboBoxItem>Bó</ComboBoxItem>
                                    </ComboBox>

                                    <DatePicker materialDesign:HintAssist.Hint="Ngày nhập" SelectedDate="{Binding DateIn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintDatePicker}" Margin="0 8 0 0"/>

                                    <TextBox materialDesign:HintAssist.Hint="Nguồn nhập" Text="{Binding Suplier, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 8 0 0"/>
                                    <TextBox materialDesign:HintAssist.Hint="Liên lạc" Text="{Binding SuplierInfo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 8 0 0"/>
                                </StackPanel>
                            </ScrollViewer>
                            <Button Grid.Row="1" Command="{Binding AddCM}" Margin="0 12 0 0" Height="46" Background="#1C3879" Foreground="White" BorderThickness="0" materialDesign:ButtonAssist.CornerRadius="8">
                                <TextBlock Text="THÊM PHIẾU NHẬP" FontWeight="Bold"/>
                            </Button>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Sửa phiếu">
                        <Grid Margin="8" FocusManager.FocusedElement="{Binding ElementName=EditHistoryCombo}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0 0 0 8">
                                <ComboBox x:Name="EditHistoryCombo" materialDesign:HintAssist.Hint="Phiếu nhập gần đây (chọn để sửa)"
                                          ItemsSource="{Binding ListIn}" SelectedItem="{Binding SelectedInputHistory, Mode=TwoWay}"
                                          IsEnabled="{Binding CanSelectHistory}" DisplayMemberPath="HistoryDisplay"
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}" Height="45"/>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBox materialDesign:HintAssist.Hint="Mã nhập" Text="{Binding ID, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 8 0 0"/>

                                    <TextBox materialDesign:HintAssist.Hint="Tên sản phẩm" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 8 0 0"/>

                                    <TextBox materialDesign:HintAssist.Hint="Số lượng" Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 8 0 0"/>

                                    <TextBox materialDesign:HintAssist.Hint="Giá nhập" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 8 0 0"/>

                                    <ComboBox materialDesign:HintAssist.Hint="Đơn vị" SelectedValue="{Binding Unit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" Style="{StaticResource MaterialDesignFloatingHintComboBox}" Margin="0 8 0 0">
                                        <ComboBoxItem>Kg</ComboBoxItem>
                                        <ComboBoxItem>Chai</ComboBoxItem>
                                        <ComboBoxItem>Quả</ComboBoxItem>
                                        <ComboBoxItem>Gói</ComboBoxItem>
                                        <ComboBoxItem>Con</ComboBoxItem>
                                        <ComboBoxItem>Lát</ComboBoxItem>
                                        <ComboBoxItem>Cây</ComboBoxItem>
                                        <ComboBoxItem>Lon</ComboBoxItem>
                                        <ComboBoxItem>Bó</ComboBoxItem>
                                    </ComboBox>

                                    <DatePicker materialDesign:HintAssist.Hint="Ngày nhập" SelectedDate="{Binding DateIn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintDatePicker}" Margin="0 8 0 0"/>

                                    <TextBox materialDesign:HintAssist.Hint="Nguồn nhập" Text="{Binding Suplier, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 8 0 0"/>
                                    <TextBox materialDesign:HintAssist.Hint="Liên lạc" Text="{Binding SuplierInfo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 8 0 0"/>
                                </StackPanel>
                            </ScrollViewer>

                            <Button Grid.Row="2" Command="{Binding EditCM}" Margin="0 12 0 0" Height="46" Background="#10B981" Foreground="White" BorderThickness="0" materialDesign:ButtonAssist.CornerRadius="8">
                                <TextBlock Text="LƯU SỬA PHIẾU" FontWeight="Bold"/>
                            </Button>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>
    </Grid>
</UserControl>