<UserControl x:Class="QuanLyNhaHang.View.Bep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:QuanLyNhaHang.View" 
             xmlns:vm="clr-namespace:QuanLyNhaHang.ViewModel"
             mc:Ignorable="d" 
             TextElement.FontFamily="Comfortaa Light"
             TextElement.FontSize="14"
             d:DesignHeight="700" 
             d:DesignWidth="1100" 
             Background="#F4F6F9">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#FFF7ED" CornerRadius="12,12,0,0" Padding="20,15">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="ChefHat" Width="24" Height="24" Foreground="#EA580C" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="DANH SÁCH MÓN CẦN THỰC HIỆN" Foreground="#EA580C" FontWeight="Bold" FontSize="18" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="#FED7AA" Margin="0"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10">
                    <ListView x:Name="ListDone" ItemsSource="{Binding ListDone}" SelectedItem="{Binding DoneSelected}"
                              FontSize="16" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="5,8"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#F1F5F9"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn DisplayMemberBinding="{Binding TenMon}" Width="240" Header="Tên món" />
                                <GridViewColumn DisplayMemberBinding="{Binding SoLuong}" Width="130" Header="Số lượng" />
                                <GridViewColumn DisplayMemberBinding="{Binding SoBan}" Width="120" Header="Số bàn" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </ScrollViewer>

                <Button Grid.Row="2" Height="55" Margin="20,10,20,20" Command="{Binding DoneCM}" Cursor="Hand" BorderThickness="0"
                        materialDesign:ButtonAssist.CornerRadius="8">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#F97316" CornerRadius="8">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3" Color="#F97316"/>
                                </Border.Effect>
                                <TextBlock Text="ĐÃ THỰC HIỆN XONG" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="12" Margin="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F0FDF4" CornerRadius="12,12,0,0" Padding="20,15">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="SilverwareVariant" Width="24" Height="24" Foreground="#16A34A" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="DANH SÁCH MÓN CẦN PHỤC VỤ" Foreground="#16A34A" FontWeight="Bold" FontSize="18" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="#BBF7D0" Margin="0"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10">
                    <ListView ItemsSource="{Binding ListOrder}" SelectedItem="{Binding OrderSelected}"
                              FontSize="16" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="5,8"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#F1F5F9"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn DisplayMemberBinding="{Binding TenMon}" Width="240" Header="Tên món" />
                                <GridViewColumn DisplayMemberBinding="{Binding SoLuong}" Width="130" Header="Số lượng" />
                                <GridViewColumn DisplayMemberBinding="{Binding SoBan}" Width="120" Header="Số bàn" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </ScrollViewer>

                <Button Grid.Row="2" Height="55" Margin="20,10,20,20" Command="{Binding OrderCM}" Cursor="Hand" BorderThickness="0"
                        materialDesign:ButtonAssist.CornerRadius="8">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#10B981" CornerRadius="8">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3" Color="#10B981"/>
                                </Border.Effect>
                                <TextBlock Text="ĐÃ PHỤC VỤ CHO KHÁCH" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

    </Grid>
</UserControl>