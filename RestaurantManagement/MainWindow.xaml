<Window x:Class="Project.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        xmlns:vm="clr-namespace:QuanLyNhaHang.ViewModel"
        xmlns:uc="clr-namespace:QuanLyNhaHang.UserControlRS"
        mc:Ignorable="d"
        x:Name="Window"
        TextElement.FontFamily="Comfortaa"
        Title="Restaurant Management" Height="820" Width="1360" WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        WindowState="Maximized"
        DataContext="{DynamicResource MainVM}"
        Style="{StaticResource Font}">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded" >
            <i:InvokeCommandAction Command="{Binding LoadWindowCommand }"  CommandParameter="{Binding ElementName=Window}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Border Background="White">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Margin" Value="10"/>
                    <Setter Property="CornerRadius" Value="10"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="#444444" Opacity="0.3"/>
                        </Setter.Value>
                    </Setter>

                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ElementName=Window, Path=WindowState}" Value="Maximized">
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="CornerRadius" Value="0"/>
                            <Setter Property="Effect" Value="{x:Null}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid MouseDown="Border_MouseDown">
                <Grid.Resources>
                    <Style x:Key="HeaderIconButton" TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#8b99d4"/>
                        <Setter Property="Width" Value="40"/>
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="20">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E2E8F0"/>
                                <Setter Property="Foreground" Value="#1C3879"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <Style x:Key="LogoutButtonStyle" TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#BAD7E9"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Margin="20 0 20 0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A4893"/>
                                <Setter Property="Foreground" Value="#ffffff"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <Style x:Key="HeaderProfileButton" TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Padding" Value="10 5"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="25">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Resources>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#1C3879"/>
                            <Setter Property="CornerRadius" Value="10 0 0 10"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=Window, Path=WindowState}" Value="Maximized">
                                    <Setter Property="CornerRadius" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="220"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="80"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image Source="pack://application:,,,/images/logo.png" Width="130" Height="130" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Foreground="#ffffff" TextAlignment="Center" FontSize="22" FontWeight="Bold" Margin="0 10 0 0">Ninres RM</TextBlock>
                        </StackPanel>

                        <uc:EmployeeNavigator Grid.Row="1" DataContext="{Binding Navigator}" Visibility="{Binding EmployeeView}"/>
                        <uc:Navigator Grid.Row="1" DataContext="{Binding Navigator}" Visibility="{Binding AdminView}"/>

                        <Button Grid.Row="2" Style="{StaticResource LogoutButtonStyle}" Command="{Binding LogOutCommand}" CommandParameter="{Binding ElementName=Window}" Height="50">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="RightFromBracket" Foreground="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="20"/>
                                <TextBlock Margin="15 0 0 0" Text="Đăng xuất" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Foreground="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Column="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F4F6F9"/>
                            <Setter Property="CornerRadius" Value="0 10 10 0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=Window, Path=WindowState}" Value="Maximized">
                                    <Setter Property="CornerRadius" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid x:Name="main_section">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="90"/>
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <UserControl x:Name="HeaderControl" Grid.Row="0">
                            <Border Background="#ffffff" CornerRadius="12" Margin="20 20 20 0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#000000" Opacity="0.05"/>
                                </Border.Effect>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" FontSize="24" FontWeight="Bold" Foreground="#1e293b" Margin="25 0 0 0" VerticalAlignment="Center" Text="{Binding Navigator.CurrentTitle}" />

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" Margin="0 0 20 0">

                                        <Grid Margin="0 0 15 0" VerticalAlignment="Center">
                                            <Button Style="{StaticResource HeaderIconButton}">
                                                <fa:IconImage Icon="Bell" Width="20" Height="20" Foreground="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                            </Button>

                                            <Border Background="#E63946" MinWidth="20" Height="20" CornerRadius="10" Padding="4 0" 
                                                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0 -2 -2 0">
                                                <TextBlock Text="{Binding NumberOfDishesNeedServing}" Foreground="White" FontSize="11" TextAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>

                                        <Button Style="{StaticResource HeaderProfileButton}" Click="ShowUser_Click" Margin="0 0 15 0">
                                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                                <Border Width="45" Height="45" CornerRadius="25" BorderThickness="2" BorderBrush="#E2E8F0">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding CaiDatViewModel.NhanVien.AnhDaiDien, Mode=OneWay}" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                </Border>
                                                <TextBlock Margin="12 0 10 0" Text="{Binding CaiDatViewModel.NhanVien.HoTen, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0 15" Background="#CBD5E1"/>

                                        <Button Style="{StaticResource HeaderIconButton}" Margin="15 0 0 0" 
                                                Command="{Binding HeaderViewModel.CloseWindowCommand}" CommandParameter="{Binding ElementName=HeaderControl}">
                                            <fa:IconImage Icon="PowerOff" Width="20" Height="20" Foreground="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </UserControl>

                        <Border Grid.Row="1" CornerRadius="12" Background="#ffffff" Margin="20 20 20 20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#000000" Opacity="0.05"/>
                            </Border.Effect>
                            <ContentControl Content="{Binding Navigator.CurrentViewModel}"></ContentControl>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>