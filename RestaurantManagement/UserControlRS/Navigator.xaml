<UserControl x:Class="QuanLyNhaHang.UserControlRS.Navigator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp" 
             xmlns:nav="clr-namespace:QuanLyNhaHang.State.Navigator" 
             d:DataContext="{d:DesignInstance Type=nav:Navigator}"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid>
        <Grid.Resources>
            <Style x:Key="sidebarRadioButton" TargetType="RadioButton">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#8b99d4"/>
                <Setter Property="Margin" Value="0 2 0 2"/>
                <Setter Property="Height" Value="50"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Tag" Value="#6673b7"/>
                <Setter Property="BorderBrush" Value="Transparent"/>

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderThickness="5 0 0 0" 
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    CornerRadius="0 8 8 0"
                                    Margin="0 0 15 0">
                                <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>

                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="#ffffff"/>
                        <Setter Property="Tag" Value="#a5a1f5"/>
                        <Setter Property="BorderBrush" Value="#a5a1f5"/>
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#31407b" Offset="0"/>
                                    <GradientStop Color="#495385" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                    </Trigger>

                    <Trigger Property="IsChecked" Value="True">
                        <Setter Property="Foreground" Value="#ffffff"/>
                        <Setter Property="Tag" Value="#ffffff"/>
                        <Setter Property="BorderBrush" Value="#a5a1f5"/>
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#31407b" Offset="0"/>
                                    <GradientStop Color="#495385" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="sidebarRadioButtonIcon" TargetType="fa:IconImage">
                <Setter Property="Width" Value="22"/>
                <Setter Property="Height" Value="22"/>
                <Setter Property="Margin" Value="25 0 15 0"/>
                <Setter Property="Foreground" Value="{Binding Path=Tag, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type RadioButton}}}"/>
            </Style>

            <Style x:Key="sideBarRadioButtonText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="{Binding Path=Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type RadioButton}}}"/>
            </Style>
        </Grid.Resources>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" BorderThickness="0">
            <StackPanel Margin="0 10 0 0">
                <Separator Height="1" Margin="20 15 35 25" Background="#46558a"/>

                <RadioButton IsChecked="True" Style="{StaticResource sidebarRadioButton}" 
                             Command="{Binding SelectViewModelCommand}" CommandParameter="{x:Static nav:TypeOfView.MenuAdmin}">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="BowlFood" Style="{StaticResource sidebarRadioButtonIcon}" />
                        <TextBlock Text="Menu" Style="{StaticResource sideBarRadioButtonText}" />
                    </StackPanel>
                </RadioButton>

                <RadioButton Style="{StaticResource sidebarRadioButton}" 
                             Command="{Binding SelectViewModelCommand}" CommandParameter="{x:Static nav:TypeOfView.TinhTrangBan}">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="Check" Style="{StaticResource sidebarRadioButtonIcon}" />
                        <TextBlock Text="Tình Trạng Bàn" Style="{StaticResource sideBarRadioButtonText}" />
                    </StackPanel>
                </RadioButton>

                <RadioButton Style="{StaticResource sidebarRadioButton}" 
                             Command="{Binding SelectViewModelCommand}" CommandParameter="{x:Static nav:TypeOfView.LichSuBan}">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="History" Style="{StaticResource sidebarRadioButtonIcon}" />
                        <TextBlock Text="Lịch Sử Bàn" Style="{StaticResource sideBarRadioButtonText}" />
                    </StackPanel>
                </RadioButton>

                <RadioButton Style="{StaticResource sidebarRadioButton}" 
                             Command="{Binding SelectViewModelCommand}" CommandParameter="{x:Static nav:TypeOfView.Bep}">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="KitchenSet" Style="{StaticResource sidebarRadioButtonIcon}" />
                        <TextBlock Text="Bếp" Style="{StaticResource sideBarRadioButtonText}" />
                    </StackPanel>
                </RadioButton>

                <RadioButton Style="{StaticResource sidebarRadioButton}" 
                             Command="{Binding SelectViewModelCommand}" CommandParameter="{x:Static nav:TypeOfView.Kho}">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="Warehouse" Style="{StaticResource sidebarRadioButtonIcon}" />
                        <TextBlock Text="Kho" Style="{StaticResource sideBarRadioButtonText}" />
                    </StackPanel>
                </RadioButton>

                <RadioButton Style="{StaticResource sidebarRadioButton}" 
                             Command="{Binding SelectViewModelCommand}" CommandParameter="{x:Static nav:TypeOfView.NhanVien}" >
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="PeopleGroup" Style="{StaticResource sidebarRadioButtonIcon}" />
                        <TextBlock Text="Nhân Viên" Style="{StaticResource sideBarRadioButtonText}" />
                    </StackPanel>
                </RadioButton>

                <RadioButton Style="{StaticResource sidebarRadioButton}" 
                             Command="{Binding SelectViewModelCommand}" CommandParameter="{x:Static nav:TypeOfView.ThongKe}">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="ChartLine" Style="{StaticResource sidebarRadioButtonIcon}" />
                        <TextBlock Text="Thống Kê" Style="{StaticResource sideBarRadioButtonText}" />
                    </StackPanel>
                </RadioButton>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>